generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int      @id @default(autoincrement())
  email              String   @unique @db.VarChar(255)
  password_hash      String   @db.VarChar(255)
  name               String?  @db.VarChar(255)
  role               String   @db.VarChar(20)
  avatar_url         String?
  email_verified     Boolean  @default(false)
  verification_token String?  @db.VarChar(255)
  password_reset_otp_hash   String?   @db.VarChar(255)
  password_reset_otp_expires DateTime? @db.Timestamptz(6)
  phone              String?  @unique @db.VarChar(32)
  phone_verified     Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz(6)

  candidate_profile         CandidateProfile?
  engineer_profile          EngineerProfile?
  jobs                      Job[]
  applications              Application[]
  referrals_made            Referral[]  @relation("EngineerReferrals")
  referrals_received        Referral[]  @relation("CandidateReferrals")
  payments                  Payment[]   @relation("UserPayments")
  engineer_payments         Payment[]   @relation("EngineerPayments")
  documents                 Document[]
  interviews_as_candidate   Interview[] @relation("CandidateInterviews")
  interviews_as_engineer    Interview[] @relation("EngineerInterviews")
  otp_challenges            OtpChallenge[]

  @@map("users")
}

model CandidateProfile {
  id               Int      @id @default(autoincrement())
  user_id          Int      @unique
  skills           String[]
  resume_url       String?
  github           String?  @db.VarChar(255)
  portfolio        String?  @db.VarChar(255)
  bio              String?
  location         String?  @db.VarChar(255)
  experience_level String?  @db.VarChar(50)
  projects         Json?
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("candidate_profiles")
}

model EngineerProfile {
  id               Int      @id @default(autoincrement())
  user_id          Int      @unique
  company          String?  @db.VarChar(255)
  designation      String?  @db.VarChar(255)
  experience_years Int?     @default(0)
  experience_band  String?  @db.VarChar(20)
  linkedin         String?  @db.VarChar(512)
  skills           String[]
  verified         Boolean  @default(false)
  bio              String?
  location         String?  @db.VarChar(255)
  company_email              String?  @db.VarChar(255)
  company_email_verified     Boolean  @default(false)
  proof_document_url         String?
  can_refer_in_company       Boolean  @default(false)
  referral_companies         String[] @default([])
  max_referrals_per_month    Int?
  can_mock_interviews        Boolean  @default(false)
  interview_types            String[] @default([])
  interview_experience_notes String?
  hours_per_week             Int?
  preferred_time_slots       Json?
  payment_method             String?  @db.VarChar(32)
  payment_details_encrypted  String?
  terms_accepted_at          DateTime? @db.Timestamptz(6)
  referral_policy_accepted_at DateTime? @db.Timestamptz(6)
  onboarding_step            Int      @default(0)
  onboarding_wizard_completed Boolean @default(true)
  onboarding_draft           Json?
  admin_verification_status  String   @default("not_submitted") @db.VarChar(32)
  submitted_for_review_at    DateTime? @db.Timestamptz(6)
  trust_score                Int      @default(0)
  badges                     String[] @default([])
  successful_hires_count     Int      @default(0)
  interviews_completed_count Int      @default(0)
  primary_email_otp_verified Boolean @default(false)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("engineer_profiles")
}

/// Short-lived OTP for phone, company email, or account email confirmation during onboarding.
model OtpChallenge {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  channel    String   @db.VarChar(16)
  target     String   @db.VarChar(255)
  purpose    String   @db.VarChar(64)
  code_hash  String   @db.VarChar(255)
  expires_at DateTime @db.Timestamptz(6)
  attempts   Int      @default(0)
  consumed   Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user User? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([target, purpose, consumed])
  @@index([user_id, purpose, consumed])
  @@map("otp_challenges")
}

model Job {
  id              Int      @id @default(autoincrement())
  company_id      Int
  title           String   @db.VarChar(255)
  description     String?
  location        String?  @db.VarChar(255)
  salary_range    String?  @db.VarChar(100)
  skills_required String[]
  status          String   @default("active") @db.VarChar(20)
  posted_at       DateTime @default(now()) @db.Timestamptz(6)

  company      User          @relation(fields: [company_id], references: [id], onDelete: Cascade)
  applications Application[]
  referrals    Referral[]

  @@map("jobs")
}

model Application {
  id           Int      @id @default(autoincrement())
  candidate_id Int
  job_id       Int
  status       String   @default("applied") @db.VarChar(30)
  applied_at   DateTime @default(now()) @db.Timestamptz(6)

  candidate User @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  job       Job  @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@unique([candidate_id, job_id])
  @@map("applications")
}

model Referral {
  id           Int      @id @default(autoincrement())
  engineer_id  Int
  candidate_id Int
  job_id       Int
  status       String   @default("pending") @db.VarChar(20)
  note         String?
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  engineer  User      @relation("EngineerReferrals", fields: [engineer_id], references: [id], onDelete: Cascade)
  candidate User      @relation("CandidateReferrals", fields: [candidate_id], references: [id], onDelete: Cascade)
  job       Job       @relation(fields: [job_id], references: [id], onDelete: Cascade)
  payments  Payment[]
  document  Document?

  @@map("referrals")
}

model Payment {
  id             Int      @id @default(autoincrement())
  user_id        Int
  engineer_id    Int?
  referral_id    Int?
  amount         Decimal  @db.Decimal(10, 2)
  type           String   @db.VarChar(30)
  status         String   @default("pending") @db.VarChar(20)
  transaction_id String?  @db.VarChar(255)
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  user     User      @relation("UserPayments", fields: [user_id], references: [id], onDelete: Cascade)
  engineer User?     @relation("EngineerPayments", fields: [engineer_id], references: [id])
  referral Referral? @relation(fields: [referral_id], references: [id])

  @@map("payments")
}

model Document {
  id                 Int      @id @default(autoincrement())
  candidate_id       Int
  referral_id        Int?     @unique
  offer_letter_url   String?
  joining_letter_url String?
  salary_slip_url    String?
  verified           Boolean  @default(false)
  uploaded_at        DateTime @default(now()) @db.Timestamptz(6)

  candidate User      @relation(fields: [candidate_id], references: [id], onDelete: Cascade)
  referral  Referral? @relation(fields: [referral_id], references: [id])

  @@unique([candidate_id, referral_id])
  @@map("documents")
}

model Interview {
  id           Int       @id @default(autoincrement())
  candidate_id Int
  engineer_id  Int
  scheduled_at DateTime? @db.Timestamptz(6)
  status       String    @default("booked") @db.VarChar(20)
  notes        String?
  feedback     String?
  created_at   DateTime  @default(now()) @db.Timestamptz(6)

  candidate User @relation("CandidateInterviews", fields: [candidate_id], references: [id], onDelete: Cascade)
  engineer  User @relation("EngineerInterviews", fields: [engineer_id], references: [id], onDelete: Cascade)

  @@map("interviews")
}
